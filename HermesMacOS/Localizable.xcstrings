    "Searches the Mac dashboard server through /api/sessions/search/conversations. Natural words and SQLite FTS-style queries are accepted; matching sessions are returned as full conversations." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durchsucht den Mac-Dashboard-Server über /api/sessions/search/conversations. Natürliche Wörter und SQLite-FTS-Abfragen werden akzeptiert; passende Sitzungen werden als vollständige Unterhaltungen zurückgegeben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Searches the Mac dashboard server through /api/sessions/search/conversations. Natural words and SQLite FTS-style queries are accepted; matching sessions are returned as full conversations."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Busca en el servidor del panel del Mac mediante /api/sessions/search/conversations. Se aceptan palabras naturales y consultas estilo SQLite FTS; las sesiones coincidentes se devuelven como conversaciones completas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Interroge le serveur du tableau de bord Mac via /api/sessions/search/conversations. Les mots naturels et les requêtes de style SQLite FTS sont acceptés ; les sessions correspondantes sont renvoyées sous forme de conversations complètes."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "通过 /api/sessions/search/conversations 搜索 Mac 仪表板服务器。支持自然语言词语和 SQLite FTS 风格查询；匹配的会话会作为完整对话返回。"
          }
        }
      }
    },
