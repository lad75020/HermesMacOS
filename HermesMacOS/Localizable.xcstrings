          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La pestaña de macOS usa el mismo flujo de la API Responses de Hermes que HermesiOS: selección de perfil, streaming SSE, cancelación, continuación de sesión y adjuntos de archivos/imágenes."
          }
        },
        "fr" : {
          "stringUnit" : {
